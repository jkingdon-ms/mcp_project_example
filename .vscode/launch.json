{
   "version": "0.2.0",
   "configurations": [
      {
         "name": "Webapp",
         "type": "debugpy",
         "request": "launch",
         "module": "streamlit",
         "args": [
            "run",
            "app.py"
         ],
         "python": "${workspaceFolder}/.venv/bin/python",
         "cwd": "${workspaceFolder}/webapp",
         "env": {
            "PYTHONPATH": "${workspaceFolder}"
         },
         "console": "integratedTerminal"
      },
      {
         "name": "Evaluation",
         "type": "debugpy",
         "request": "launch",
         "program": "${workspaceFolder}/evaluation/run_eval.py",
         "python": "${workspaceFolder}/.venv/bin/python",
         "args": [
            "--batch-size",
            "4"
         ],
         "cwd": "${workspaceFolder}/evaluation",
         "env": {
            "PYTHONPATH": "${workspaceFolder}"
         },
         "console": "integratedTerminal"
      },
      {
         "name": "MCP Server",
         "type": "debugpy",
         "request": "launch",
         "program": "${workspaceFolder}/mcp/server/server.py",
         "python": "${workspaceFolder}/.venv/bin/python",
         "cwd": "${workspaceFolder}/mcp/server",
         "env": {
            "PYTHONPATH": "${workspaceFolder}"
         },
         "console": "integratedTerminal"
      },
      {
         "name": "MCP Client",
         "type": "debugpy",
         "request": "launch",
         "program": "${workspaceFolder}/mcp/client/client.py",
         "python": "${workspaceFolder}/.venv/bin/python",
         "cwd": "${workspaceFolder}/mcp/client",
         "env": {
            "PYTHONPATH": "${workspaceFolder}"
         },
         "console": "integratedTerminal"
      },
      {
         "name": "API Server",
         "type": "debugpy",
         "request": "launch",
         "module": "openapi_server",
         "python": "${workspaceFolder}/.venv/bin/python",
         "cwd": "${workspaceFolder}/api/server",
         "console": "integratedTerminal"
      },
      {
         "name": "API Client Tests",
         "type": "debugpy",
         "request": "launch",
         "module": "pytest",
         "python": "${workspaceFolder}/.venv/bin/python",
         "args": [
            "test/",
            "-v"
         ],
         "cwd": "${workspaceFolder}/api/client",
         "env": {
            "PYTHONPATH": "${workspaceFolder}/api/server"
         },
         "console": "integratedTerminal"
      }
   ]
}