{
   "name": "Python Dev",
   "image": "mcr.microsoft.com/devcontainers/python:3.12",
   "mounts": [
      "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
   ],
   "customizations": {
      "vscode": {
         "extensions": [
            "ms-python.python",
            "ms-python.vscode-pylance",
            "github.copilot-chat",
            "charliermarsh.ruff"
         ]
      }
   },
   "postCreateCommand": "bash .devcontainer/postCreate.sh"
}